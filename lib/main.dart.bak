import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  // This widget is the root of your application.
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Flutter Demo',
      theme: ThemeData(
        import 'package:flutter/material.dart';
        import 'services/api_service.dart';
        import 'screens/login_screen.dart';
        import 'screens/home_screen.dart';

        void main() {
          runApp(const DolapApp());
        }

        class DolapApp extends StatelessWidget {
          const DolapApp({super.key});

          @override
          Widget build(BuildContext context) {
            return MaterialApp(
              title: 'Dolap',
              debugShowCheckedModeBanner: false,
              theme: ThemeData(
                colorScheme: ColorScheme.fromSeed(
                  seedColor: const Color(0xFF2D2D2D),
                  brightness: Brightness.light,
                ),
                useMaterial3: true,
              ),
              home: const SplashRouter(),
            );
          }
        }

        // Token varsa direkt HomeScreen, yoksa LoginScreen'e yönlendir
        class SplashRouter extends StatefulWidget {
          const SplashRouter({super.key});

          @override
          State<SplashRouter> createState() => _SplashRouterState();
        }

        class _SplashRouterState extends State<SplashRouter> {
          @override
          void initState() {
            super.initState();
            _checkAuth();
          }

          Future<void> _checkAuth() async {
            final token = await ApiService.getToken();
            if (!mounted) return;
            Navigator.pushReplacement(
              context,
              MaterialPageRoute(
                builder: (_) =>
                    token != null ? const HomeScreen() : const LoginScreen(),
              ),
            );
          }

          @override
          Widget build(BuildContext context) {
            return const Scaffold(
              backgroundColor: Color(0xFFF8F4F0),
              body: Center(
                child: Column(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    Icon(Icons.checkroom, size: 60, color: Color(0xFF2D2D2D)),
                    SizedBox(height: 16),
                    Text(
                      'Dolap',
                      style: TextStyle(
                        fontSize: 28,
                        fontWeight: FontWeight.bold,
                        color: Color(0xFF2D2D2D),
                      ),
                    ),
                  ],
                ),
              ),
            );
          }
        }
          //
